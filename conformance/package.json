{
  "name": "tsop-conformance",
  "version": "0.1.0",
  "private": true,
  "description": "Conformance test infrastructure for verifying TSOP compiler implementations produce identical output",
  "type": "module",
  "scripts": {
    "test": "tsx runner/index.ts",
    "test:json": "tsx runner/index.ts --format json",
    "test:markdown": "tsx runner/index.ts --format markdown",
    "test:filter": "tsx runner/index.ts --filter",
    "update-golden": "tsx runner/index.ts --update-golden",
    "fuzz": "tsx fuzzer/index.ts",
    "fuzz:quick": "tsx fuzzer/index.ts --num 10 --verbose",
    "fuzz:property": "tsx fuzzer/index.ts --property"
  },
  "dependencies": {
    "fast-check": "^3.22.0"
  },
  "devDependencies": {
    "tsx": "^4.0.0",
    "typescript": "^5.6.0"
  }
}
