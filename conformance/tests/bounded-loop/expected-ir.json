{
  "contractName": "BoundedLoop",
  "properties": [
    {
      "name": "expectedSum",
      "type": "bigint",
      "readonly": true
    }
  ],
  "methods": [
    {
      "name": "constructor",
      "params": [
        {
          "name": "expectedSum",
          "type": "bigint"
        }
      ],
      "body": [
        {
          "name": "t0",
          "value": {
            "kind": "load_prop",
            "name": "expectedSum"
          }
        },
        {
          "name": "t1",
          "value": {
            "kind": "call",
            "func": "super",
            "args": [
              "t0"
            ]
          }
        },
        {
          "name": "t2",
          "value": {
            "kind": "load_prop",
            "name": "expectedSum"
          }
        },
        {
          "name": "t3",
          "value": {
            "kind": "update_prop",
            "name": "expectedSum",
            "value": "t2"
          }
        }
      ],
      "isPublic": false
    },
    {
      "name": "verify",
      "params": [
        {
          "name": "start",
          "type": "bigint"
        }
      ],
      "body": [
        {
          "name": "t0",
          "value": {
            "kind": "load_const",
            "value": 0
          }
        },
        {
          "name": "sum",
          "value": {
            "kind": "load_const",
            "value": "@ref:t0"
          }
        },
        {
          "name": "t5",
          "value": {
            "kind": "loop",
            "count": 5,
            "body": [
              {
                "name": "t1",
                "value": {
                  "kind": "load_param",
                  "name": "start"
                }
              },
              {
                "name": "t2",
                "value": {
                  "kind": "bin_op",
                  "op": "+",
                  "left": "sum",
                  "right": "t1"
                }
              },
              {
                "name": "t3",
                "value": {
                  "kind": "load_param",
                  "name": "i"
                }
              },
              {
                "name": "t4",
                "value": {
                  "kind": "bin_op",
                  "op": "+",
                  "left": "t2",
                  "right": "t3"
                }
              },
              {
                "name": "sum",
                "value": {
                  "kind": "load_const",
                  "value": "@ref:t4"
                }
              }
            ],
            "iterVar": "i"
          }
        },
        {
          "name": "t6",
          "value": {
            "kind": "load_prop",
            "name": "expectedSum"
          }
        },
        {
          "name": "t7",
          "value": {
            "kind": "bin_op",
            "op": "===",
            "left": "sum",
            "right": "t6"
          }
        },
        {
          "name": "t8",
          "value": {
            "kind": "assert",
            "value": "t7"
          }
        }
      ],
      "isPublic": true
    }
  ]
}
