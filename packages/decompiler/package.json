{
  "name": "runar-decompiler",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "description": "Bitcoin Script → Rúnar TypeScript decompiler (left inverse of the TS compiler)",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:roundtrip": "vitest run __tests__/roundtrip.test.ts",
    "test:handrolled": "vitest run __tests__/hand-rolled.test.ts",
    "test:fingerprints": "vitest run __tests__/fingerprints.test.ts",
    "fingerprints:build": "tsx scripts/build-fingerprints.ts",
    "templates:build": "tsx scripts/generate-templates.ts",
    "coverage": "tsx scripts/coverage-matrix.ts",
    "decompile": "tsx scripts/decompile-cli.ts",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "files": ["dist", "fingerprints.json", "coverage-baseline.json"],
  "license": "MIT",
  "dependencies": {
    "runar-compiler": "workspace:*",
    "runar-testing": "workspace:*",
    "runar-ir-schema": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "tsx": "^4.19.0"
  }
}
