{
  "name": "runar-ir-schema",
  "version": "0.1.0",
  "type": "module",
  "description": "JSON Schema definitions and validators for Rúnar IR formats",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc && cp -r src/schemas dist/schemas",
    "test": "vitest run",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "files": ["dist", "src/schemas"],
  "dependencies": {
    "ajv": "^8.17.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
