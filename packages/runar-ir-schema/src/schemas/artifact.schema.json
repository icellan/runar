{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runar.dev/schemas/artifact.schema.json",
  "title": "Rúnar Artifact",
  "description": "Compiled output of a Rúnar compiler — locking script, ABI, and optional debug info.",
  "type": "object",
  "required": [
    "version",
    "compilerVersion",
    "contractName",
    "abi",
    "script",
    "asm",
    "buildTimestamp"
  ],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^runar-v\\d+\\.\\d+\\.\\d+$"
    },
    "compilerVersion": {
      "type": "string",
      "minLength": 1
    },
    "contractName": {
      "type": "string",
      "minLength": 1
    },
    "abi": { "$ref": "#/$defs/ABI" },
    "script": {
      "type": "string",
      "pattern": "^([0-9a-fA-F]{2})*$",
      "description": "Hex-encoded locking script"
    },
    "asm": {
      "type": "string",
      "description": "Human-readable assembly (space-separated opcodes)"
    },
    "sourceMap": { "$ref": "#/$defs/SourceMap" },
    "ir": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "anf": {
          "$ref": "anf-ir.schema.json",
          "description": "Optional ANF IR snapshot for debugging"
        },
        "stack": {
          "type": "object",
          "description": "Optional Stack IR snapshot for debugging"
        }
      }
    },
    "anf": {
      "$ref": "anf-ir.schema.json",
      "description": "ANF IR for SDK state computation (always included for stateful contracts)"
    },
    "stateFields": {
      "type": "array",
      "items": { "$ref": "#/$defs/StateField" }
    },
    "constructorSlots": {
      "type": "array",
      "items": { "$ref": "#/$defs/ConstructorSlot" },
      "description": "Byte offsets of constructor parameter placeholders in the script"
    },
    "codeSepIndexSlots": {
      "type": "array",
      "items": { "$ref": "#/$defs/CodeSepIndexSlot" },
      "description": "Byte offsets of codeSepIndex placeholders in the script"
    },
    "codeSeparatorIndex": {
      "type": "integer",
      "minimum": 0,
      "description": "Byte offset of OP_CODESEPARATOR in the locking script (for BIP-143 sighash)"
    },
    "codeSeparatorIndices": {
      "type": "array",
      "items": { "type": "integer", "minimum": 0 },
      "description": "Per-method OP_CODESEPARATOR byte offsets (index 0 = first public method, etc.)"
    },
    "buildTimestamp": {
      "type": "string",
      "description": "ISO-8601 date-time string",
      "minLength": 1
    }
  },
  "$defs": {
    "ABI": {
      "type": "object",
      "required": ["constructor", "methods"],
      "additionalProperties": false,
      "properties": {
        "constructor": { "$ref": "#/$defs/ABIConstructor" },
        "methods": {
          "type": "array",
          "items": { "$ref": "#/$defs/ABIMethod" }
        }
      }
    },
    "ABIConstructor": {
      "type": "object",
      "required": ["params"],
      "additionalProperties": false,
      "properties": {
        "params": {
          "type": "array",
          "items": { "$ref": "#/$defs/ABIParam" }
        }
      }
    },
    "ABIMethod": {
      "type": "object",
      "required": ["name", "params", "isPublic"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "params": {
          "type": "array",
          "items": { "$ref": "#/$defs/ABIParam" }
        },
        "isPublic": { "type": "boolean" },
        "isTerminal": {
          "type": "boolean",
          "description": "True for stateful contract methods that don't mutate state (no continuation output)."
        }
      }
    },
    "ABIParam": {
      "type": "object",
      "required": ["name", "type"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "type": { "type": "string", "minLength": 1 },
        "fixedArray": { "$ref": "#/$defs/FixedArrayInfo" }
      }
    },
    "FixedArrayInfo": {
      "type": "object",
      "required": ["elementType", "length", "syntheticNames"],
      "additionalProperties": false,
      "properties": {
        "elementType": { "type": "string", "minLength": 1 },
        "length": { "type": "integer", "minimum": 1 },
        "syntheticNames": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "SourceMap": {
      "type": "object",
      "required": ["mappings"],
      "additionalProperties": false,
      "properties": {
        "mappings": {
          "type": "array",
          "items": { "$ref": "#/$defs/SourceMapping" }
        }
      }
    },
    "SourceMapping": {
      "type": "object",
      "required": ["opcodeIndex", "sourceFile", "line", "column"],
      "additionalProperties": false,
      "properties": {
        "opcodeIndex": { "type": "integer", "minimum": 0 },
        "sourceFile": { "type": "string", "minLength": 1 },
        "line": { "type": "integer", "minimum": 1 },
        "column": { "type": "integer", "minimum": 0 }
      }
    },
    "StateFieldInitialValue": {
      "description": "Compile-time default value. Scalar fields use string|integer|boolean; grouped FixedArray fields use a (possibly nested) array of element values.",
      "oneOf": [
        { "type": "string" },
        { "type": "integer" },
        { "type": "boolean" },
        {
          "type": "array",
          "items": { "$ref": "#/$defs/StateFieldInitialValue" }
        }
      ]
    },
    "StateField": {
      "type": "object",
      "required": ["name", "type", "index"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "type": { "type": "string", "minLength": 1 },
        "index": { "type": "integer", "minimum": 0 },
        "initialValue": { "$ref": "#/$defs/StateFieldInitialValue" },
        "fixedArray": { "$ref": "#/$defs/FixedArrayInfo" }
      }
    },
    "ConstructorSlot": {
      "type": "object",
      "required": ["paramIndex", "byteOffset"],
      "additionalProperties": false,
      "properties": {
        "paramIndex": { "type": "integer", "minimum": 0 },
        "byteOffset": { "type": "integer", "minimum": 0 }
      }
    },
    "CodeSepIndexSlot": {
      "type": "object",
      "required": ["byteOffset", "codeSepIndex"],
      "additionalProperties": false,
      "properties": {
        "byteOffset": {
          "type": "integer",
          "minimum": 0,
          "description": "Byte offset of the OP_0 placeholder in the template script"
        },
        "codeSepIndex": {
          "type": "integer",
          "minimum": 0,
          "description": "The template-relative codeSeparatorIndex value this placeholder represents"
        }
      }
    }
  }
}
