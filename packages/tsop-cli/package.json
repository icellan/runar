{
  "name": "tsop-cli",
  "version": "0.1.0",
  "type": "module",
  "description": "TSOP CLI: compile, test, deploy, and manage smart contracts",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "tsop": "dist/bin.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "files": ["dist"],
  "dependencies": {
    "commander": "^12.1.0",
    "tsop-compiler": "workspace:*",
    "tsop-sdk": "workspace:*",
    "tsop-testing": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
