                simp [supportedRefShape] at hShape
            | constValue _ _ _ _ hShape _ =>
                simp [supportedConstShape] at hShape
            | arithValue _ _ _ _ hShape _ =>
                simp [supportedArithShape] at hShape
            | callValue _ _ _ _ hShape _ =>
