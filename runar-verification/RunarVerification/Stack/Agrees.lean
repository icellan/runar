private theorem runOps_loadThen_ABS
    (loadOps : List StackOp) (stkSt : StackState) (i : Int)
    (hLoadRun : runOps loadOps stkSt = .ok (stkSt.push (.vBigint i))) :
    runOps (loadOps ++ [.opcode "OP_ABS"]) stkSt =
      .ok (stkSt.push (.vBigint i.natAbs)) := by
