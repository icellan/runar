    · have hFresh' : freshIn bn (n :: untagSm tsm_rest) := hFresh
      -- Convert n :: untagSm tsm_rest to untagSm ((n, k) :: tsm_rest).
      have hFreshU : freshIn bn (untagSm ((n, k) :: tsm_rest)) := by
