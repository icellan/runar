    runOps [.pickStruct d, .opcode "OP_NEGATE"] stkSt
      = .ok (stkSt.push (.vBigint (-i)))
    ∧ agreesTagged ((bn, .binding) :: tsm)
                   (anfSt.addBinding bn (.vBigint (-i)))
