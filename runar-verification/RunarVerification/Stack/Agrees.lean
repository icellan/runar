        (Stack.Lower.lower
          { contractName := contractName, properties := props, methods := m :: rest })
        m.name initialStack = .ok stkFinal
    ∧ anfFinal.props = stkFinal.props
    ∧ anfFinal.outputs = stkFinal.outputs := by
