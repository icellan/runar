          | thisRef =>
              simp only [supportedANFBodyB, Bool.and_eq_true]
              refine ⟨fun ⟨hH, hR⟩ => ?_, fun h => ?_⟩
              · exact SupportedANFBody.refValue name _ src rest
                        (by simp [supportedRefShape])
                        ((supportedANFBodyB_iff rest).mp hR)
              · cases h with
