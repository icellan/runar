    rw [hPostEq] at hOp
    show runOps ([.pickStruct d] ++ [.opcode "OP_NEGATE"]) stkSt = _
    exact runOps_loadThenOpcode_unconditional [.pickStruct d] "OP_NEGATE" stkSt
