/-- UNCONDITIONAL `assert` preservation at depth ≥ 2 (vBool true). -/
theorem agreesTagged_assert_dge2_unconditional
    (tsm : TaggedStackMap) (n : String) (k : SlotKind) (d : Nat)
    (bn : String) (anfSt : State) (stkSt : StackState)
