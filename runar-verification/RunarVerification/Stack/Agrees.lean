          exact absurd hHead (by
            simp [structuralRefValue, structuralCopyValue, structuralConsumeValue])
      | updateProp _ _ =>
          exact absurd hHead (by
            simp [structuralRefValue, structuralCopyValue, structuralConsumeValue])
      | getStateScript =>
          exact absurd hHead (by
            simp [structuralRefValue, structuralCopyValue, structuralConsumeValue])
      | checkPreimage _ =>
          exact absurd hHead (by
            simp [structuralRefValue, structuralCopyValue, structuralConsumeValue])
      | deserializeState _ =>
          exact absurd hHead (by
            simp [structuralRefValue, structuralCopyValue, structuralConsumeValue])
      | addOutput _ _ _ =>
          exact absurd hHead (by
            simp [structuralRefValue, structuralCopyValue, structuralConsumeValue])
      | addRawOutput _ _ =>
          exact absurd hHead (by
            simp [structuralRefValue, structuralCopyValue, structuralConsumeValue])
      | addDataOutput _ _ =>
